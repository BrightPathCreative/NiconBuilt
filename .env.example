# Nicon Built — environment variables
# Copy to .env.local and fill in real values. Never commit real secrets.

# Public site URL
NEXT_PUBLIC_SITE_URL=https://niconbuilt.com.au

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# GoHighLevel (GHL) embedded form — site-wide (home hero, contact, service pages).
# Defaults below match the "Nicon Built Contact Us Form" embed supplied by BrightPath.
# Override only if the form is rebuilt/replaced in GHL with a new ID or embed domain.
NEXT_PUBLIC_GHL_CONTACT_FORM_ID=vvUEO6TWQDp00EySpLfv
NEXT_PUBLIC_GHL_CONTACT_FORM_SRC=https://links.brightpathcreative.com.au/widget/form/vvUEO6TWQDp00EySpLfv
NEXT_PUBLIC_GHL_FORM_EMBED_SCRIPT_SRC=https://links.brightpathcreative.com.au/js/form_embed.js

# GHL lead-gen / call-tracking number (site-wide click-to-call)
# Provision in GHL as a "Website" tracking number — label/tag calls there, not in site code.
# Buttons show "Click to call" only; the number is never displayed in the UI.
# Do NOT use 0407699454 anywhere — that is Nick's personal mobile.
NEXT_PUBLIC_PRIMARY_PHONE=

# Optional dev/staging placeholder (used when PRIMARY_PHONE is unset)
NEXT_PUBLIC_DEV_PHONE=

# VBA builder's licence number
NEXT_PUBLIC_VBA_LICENCE_NUMBER=CDB-U 62648

# Google Business Profile / Places ID (optional — only if pulling reviews live instead of using the 9 static reviews already approved in docs/copy/testimonials.md)
GOOGLE_BUSINESS_PROFILE_ID=
